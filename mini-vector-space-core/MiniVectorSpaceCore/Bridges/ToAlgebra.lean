/-! ## Tensor product of vector spaces (L3, L8)

The tensor product V ⊗ W of two vector spaces is the universal
target for bilinear maps V × W → Z. Its elements are finite sums
Σ vᵢ ⊗ wᵢ with relations encoding bilinearity.
-/

structure TensorProduct (F : Field) (VS₁ VS₂ : VectorSpace F) where
  tensorCarrier : Type u
  addT : tensorCarrier → tensorCarrier → tensorCarrier
  zeroT : tensorCarrier
  negT : tensorCarrier → tensorCarrier
  smulT : F.carrier → tensorCarrier → tensorCarrier
  ι : VS₁.V → VS₂.V → tensorCarrier

def TensorProduct.asVectorSpace {F : Field} {VS₁ VS₂ : VectorSpace F} (T : TensorProduct F VS₁ VS₂) : VectorSpace F where
  V    := T.tensorCarrier
  add  := T.addT
  zero := T.zeroT
  neg  := T.negT
  smul := T.smulT

axiom tensorProduct_exists {F : Field} (VS₁ VS₂ : VectorSpace F) : TensorProduct F VS₁ VS₂

axiom tensorProduct_bilinear {F : Field} (VS₁ VS₂ W : VectorSpace F)
    (b : BilinearMap VS₁ VS₂ W) (T : TensorProduct F VS₁ VS₂) :
    ∃! (g : LinearMap (T.asVectorSpace) W),
      ∀ (v₁ : VS₁.V) (v₂ : VS₂.V), g.mapping (T.ι v₁ v₂) = b.bilin v₁ v₂

/-! ## Dimension of tensor product (L4)

dim(V ⊗ W) = dim(V) · dim(W) for finite-dimensional spaces.
-/

axiom tensorProduct_dimension {F : Field} (VS₁ VS₂ : VectorSpace F)
    (hfin₁ : isFiniteDimensional VS₁) (hfin₂ : isFiniteDimensional VS₂)
    (T : TensorProduct F VS₁ VS₂) :
    dimension (T.asVectorSpace) = dimension VS₁ * dimension VS₂

/-! ## Exterior algebra (L8)

The exterior algebra Λ(V) is the quotient of the tensor algebra T(V)
by the ideal generated by v ⊗ v. Λᵏ(V) consists of alternating tensors.
-/

structure ExteriorPower (F : Field) (VS : VectorSpace F) (k : Nat) where
  extCarrier : Type u

def ExteriorPower.dimension {F : Field} {VS : VectorSpace F} {k : Nat} (Λ : ExteriorPower F VS k)
    (n : Nat) (hdim : dimension VS = n) : Nat :=
  Nat.choose n k

axiom exteriorPower_dimension {F : Field} (VS : VectorSpace F) (k : Nat)
    (hfin : isFiniteDimensional VS) (Λ : ExteriorPower F VS k) :
    True

/-! ## Symmetric algebra (L8)

The symmetric algebra S(V) is the quotient of T(V) by x⊗y - y⊗x.
Sᵏ(V) consists of symmetric tensors; S(V) is the polynomial ring
in dim(V) variables.
-/

structure SymmetricPower (F : Field) (VS : VectorSpace F) (k : Nat) where
  symCarrier : Type u

axiom symmetricPower_dimension {F : Field} (VS : VectorSpace F) (k : Nat)
    (hfin : isFiniteDimensional VS) (S : SymmetricPower F VS k) :
    True

/-! ## Group algebra (L7, L8)

For a group G and field F, the group algebra F[G] is the vector space
with basis G and multiplication extended from the group law.
This bridges representation theory.
-/

structure GroupAlgebra (F : Field) (G : Type u) where
  algV : VectorSpace F
  basisG : G → algV.V

axiom groupAlgebra_dimension (F : Field) (G : Type u) [Finite G] : True

/-! ## Lie algebra (L8)

A Lie algebra is a vector space g with a bilinear bracket [,]: g × g → g
satisfying antisymmetry and the Jacobi identity.
-/

structure LieAlgebra (F : Field) where
  g : VectorSpace F
  bracket : BilinearForm g
  antisym : ∀ x y, bracket.bilin x y = F.neg (bracket.bilin y x)
  jacobi : ∀ x y z, True

axiom lieAlgebra_adjoint_representation {F : Field} (L : LieAlgebra F) : True

/-! ## Universal enveloping algebra (L8, L9)

For a Lie algebra g, the universal enveloping algebra U(g) is an
associative algebra such that Lie algebra representations of g
correspond bijectively to U(g)-modules (representations of U(g)).
-/

structure UniversalEnvelopingAlgebra (F : Field) (L : LieAlgebra F) where
  alg : Algebra F
  ι : LinearMap L.g alg.algV
  universal : True

axiom PBW_theorem {F : Field} (L : LieAlgebra F) (hfin : isFiniteDimensional L.g) : True

