/-! ## Section 1: Two-Sided Ideals in Algebras -/

/-- A two-sided ideal I in an algebra A: closed under +,
contains 0, and closed under left/right multiplication. -/
structure TwoSidedIdeal (A : Type u) (add : A → A → A) (zero : A) (mul : A → A → A) where
  member : A → Prop
  zero_mem : member zero
  add_closed : ∀ (x y : A), member x → member y → member (add x y)
  left_mul : ∀ (a x : A), member x → member (mul a x)
  right_mul : ∀ (x a : A), member x → member (mul x a)

/-! ## Section 2: Commutator Ideal (for S(V)) -/

/-- The commutator ideal in T(V): generated by x⊗y - y⊗x for x,y ∈ V.
Quotient by this ideal gives S(V). -/
structure CommutatorIdeal (F : Field) (V : VectorSpace F) where
  TA : TensorAlgebra F V
  gen_pair : V.V → V.V → TA.alg → Prop
  gen_mem : ∀ (x y : V.V), gen_pair x y
    (TA.alg_add (TA.alg_mul (TA.embed_vector x) (TA.embed_vector y))
      (TA.alg_smul (F.neg F.one) (TA.alg_mul (TA.embed_vector y) (TA.embed_vector x))))

/-! ## Section 3: Square Ideal (for Λ(V)) -/

/-- The square ideal in T(V): generated by x⊗x for x ∈ V.
Quotient gives Λ(V). -/
structure SquareIdeal (F : Field) (V : VectorSpace F) where
  TA : TensorAlgebra F V
  gen_single : V.V → TA.alg → Prop
  gen_mem : ∀ (x : V.V), gen_single x (TA.alg_mul (TA.embed_vector x) (TA.embed_vector x))

/-! ## Section 4: Projections to S(V) and Λ(V) -/

/-- Projection π: T(V) → S(V) with kernel = commutator ideal. -/
structure ProjToSym (F : Field) (V : VectorSpace F) where
  TA : TensorAlgebra F V
  SA : SymmetricAlgebra F V
  proj : TA.alg → SA.carrier
  proj_mul : ∀ (x y : TA.alg), proj (TA.alg_mul x y) = SA.mul (proj x) (proj y)
  proj_add : ∀ (x y : TA.alg), proj (TA.alg_add x y) = SA.add (proj x) (proj y)
  proj_vector : ∀ (x : V.V), proj (TA.embed_vector x) = SA.embed x
  kernel_comm : ∀ (x y : V.V), proj (TA.alg_mul (TA.embed_vector x) (TA.embed_vector y)) =
    proj (TA.alg_mul (TA.embed_vector y) (TA.embed_vector x))

/-- Projection π: T(V) → Λ(V) with kernel = square ideal. -/
structure ProjToExt (F : Field) (V : VectorSpace F) where
  TA : TensorAlgebra F V
  EA : ExteriorAlgebra F V
  proj : TA.alg → EA.ealg
  proj_mul_wedge : ∀ (x y : TA.alg), proj (TA.alg_mul x y) = (proj x) ∧ (proj y)
  proj_add : ∀ (x y : TA.alg), proj (TA.alg_add x y) = EA.ea_add (proj x) (proj y)
  proj_vector : ∀ (x : V.V), proj (TA.embed_vector x) = EA.ea_embed x
  kernel_sq : ∀ (x : V.V), proj (TA.alg_mul (TA.embed_vector x) (TA.embed_vector x)) = EA.ea_zero

/-! ## Section 5: Universal Enveloping Algebra -/

/-- U(g) = T(g)/⟨x⊗y - y⊗x - [x,y]⟩. The PBW theorem states
that gr U(g) ≅ S(g) as graded algebras. -/
structure UnivEnvelAlg (F : Field) (V : VectorSpace F) where
  TA : TensorAlgebra F V
  bracket : V.V → V.V → V.V
  bracket_add_first : ∀ (x y z : V.V), bracket (V.add x y) z = V.add (bracket x z) (bracket y z)
  bracket_add_second: ∀ (x y z : V.V), bracket x (V.add y z) = V.add (bracket x y) (bracket x z)
  bracket_antisymm  : ∀ (x y : V.V), bracket x y = V.smul (F.neg F.one) (bracket y x)
  bracket_jacobi    : ∀ (x y z : V.V),
    V.add (bracket x (bracket y z)) (V.add (bracket y (bracket z x)) (bracket z (bracket x y))) = V.zero
  uea_carrier : Type u
  uea_proj : TA.alg → uea_carrier

/-- PBW: gr U(g) ≅ S(g). For abelian Lie algebra (bracket=0), U(g) = S(g). -/
structure PBWTheorem (F : Field) (V : VectorSpace F) where
  uea : UnivEnvelAlg F V
  sa : SymmetricAlgebra F V
  -- gr U(g) ≅ S(g) as graded algebras

/-! ## Section 6: Tor Functor -/

/-- Tor₁ over Z: Tor₁(Z/m, Z/n) ≅ Z/gcd(m,n). -/
def tor1ZmZn (m n : Nat) : Nat := Nat.gcd m n

